#!/usr/bin/env bash

set -euo pipefail

LAB_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

export LAB_ROOT

source "${LAB_ROOT}/lib/core/init.sh"

COMMAND="${1:-help}"

COMMAND_FILE="${LAB_ROOT}/lib/commands/${COMMAND}.sh"

if [[ ! -f "${COMMAND_FILE}" ]]; then

    error "Unknown command: ${COMMAND}"

    echo

    source "${LAB_ROOT}/lib/commands/help.sh"

    command_help

    exit 1

fi

source "${COMMAND_FILE}"

FUNCTION="command_${COMMAND}"

shift || true

"${FUNCTION}" "$@"